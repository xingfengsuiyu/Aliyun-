<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.rental.mapper.TenantMapper">

    <!-- Result Map -->
    <resultMap id="TenantResultMap" type="com.rental.entity.Tenant">
        <id property="id" column="id"/>
        <result property="landlordId" column="landlord_id"/>
        <result property="name" column="name"/>
        <result property="gender" column="gender"/>
        <result property="idCard" column="id_card"/>
        <result property="phone" column="phone"/>
        <result property="email" column="email"/>
        <result property="emergencyContactName" column="emergency_contact_name"/>
        <result property="emergencyContactPhone" column="emergency_contact_phone"/>
        <result property="propertyId" column="property_id"/>
        <result property="notes" column="notes"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        
        <!-- Collection mappings -->
        <collection property="idCardPhotos" ofType="string"
                    select="findIdPhotosByTenantId" column="id"/>
    </resultMap>

    <!-- Find ID photos by tenant ID -->
    <select id="findIdPhotosByTenantId" resultType="string">
        SELECT photo_url FROM tenant_id_photos WHERE tenant_id = #{id}
    </select>

    <!-- Find by ID -->
    <select id="findById" resultMap="TenantResultMap">
        SELECT * FROM tenants WHERE id = #{id}
    </select>

    <!-- Find by ID card -->
    <select id="findByIdCard" resultMap="TenantResultMap">
        SELECT * FROM tenants WHERE id_card = #{idCard}
    </select>

    <!-- Find by phone -->
    <select id="findByPhone" resultMap="TenantResultMap">
        SELECT * FROM tenants WHERE phone = #{phone}
    </select>

    <!-- Insert tenant -->
    <insert id="insert" parameterType="com.rental.entity.Tenant">
        INSERT INTO tenants(
            id, landlord_id, name, gender, id_card, phone, email,
            emergency_contact_name, emergency_contact_phone, property_id, status, notes, created_at
        ) VALUES(
            #{id}, #{landlordId}, #{name}, #{gender}, #{idCard}, #{phone}, #{email},
            #{emergencyContactName}, #{emergencyContactPhone}, #{propertyId}, #{status}, #{notes}, NOW()
        )
    </insert>

    <!-- Insert ID photo -->
    <insert id="insertIdPhoto">
        INSERT INTO tenant_id_photos(tenant_id, photo_url) 
        VALUES(#{tenantId}, #{photoUrl})
    </insert>

    <!-- Update tenant -->
    <update id="update" parameterType="com.rental.entity.Tenant">
        UPDATE tenants SET
            name = #{name},
            gender = #{gender},
            email = #{email},
            emergency_contact_name = #{emergencyContactName},
            emergency_contact_phone = #{emergencyContactPhone},
            property_id = #{propertyId},
            status = #{status},
            notes = #{notes}
        WHERE id = #{id}
    </update>

    <!-- Find by landlord ID -->
    <select id="findByLandlordId" resultMap="TenantResultMap">
        SELECT * FROM tenants 
        WHERE landlord_id = #{landlordId}
        ORDER BY created_at DESC
    </select>

    <!-- Count by landlord ID -->
    <select id="countByLandlordId" resultType="long">
        SELECT COUNT(*) FROM tenants WHERE landlord_id = #{landlordId}
    </select>

    <!-- Search tenants with filters -->
    <select id="searchTenants" resultMap="TenantResultMap">
        SELECT * FROM tenants
        WHERE landlord_id = #{landlordId}
        <if test="name != null and name != ''">
            AND name LIKE CONCAT('%', #{name}, '%')
        </if>
        <if test="phone != null and phone != ''">
            AND phone LIKE CONCAT('%', #{phone}, '%')
        </if>
        <if test="status != null and status != ''">
            AND status = #{status}
        </if>
        ORDER BY created_at DESC
    </select>

    <!-- Check if exists by ID card -->
    <select id="existsByIdCard" resultType="boolean">
        SELECT EXISTS(SELECT 1 FROM tenants WHERE id_card = #{idCard})
    </select>

    <!-- Check if exists by phone -->
    <select id="existsByPhone" resultType="boolean">
        SELECT EXISTS(SELECT 1 FROM tenants WHERE phone = #{phone})
    </select>

</mapper>
